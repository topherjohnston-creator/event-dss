# Event DSS Environment Variables
# Copy to .env and fill in your values
# DO NOT commit .env to git

# Synoptic Data API
# Get token at https://developers.synopticdata.com/
SYNOPTIC_TOKEN=your_synoptic_token_here

# NWS API User-Agent (optional)
# Required if hitting NWS API frequently
NWS_USER_AGENT=EventDSS/1.0 (research; your-email@example.com)

# Development settings
DEBUG=false
LOG_LEVEL=INFO

# Default location for local testing
DEFAULT_LOCATION=krno

# Paths (usually don't need to change)
CONFIG_DIR=config
DOCS_DIR=docs
DATA_DIR=data
SCRIPTS_DIR=scripts

# Feature flags
FETCH_REFS=true
FETCH_ALERTS=true
FETCH_OBS=true
